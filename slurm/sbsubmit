#!/usr/bin/env bash
set -e

# Ensure the python script is provided
if [[ -z "$1" ]]; then
    echo "Usage: $0 <script.py> [mode]"
    exit 1
fi

# Determine the mode (default to SIESTA if not provided)
SCRIPT="$1"
MODE="${2:-SIESTA}"
MODE="$(echo "$MODE" | tr '[:lower:]' '[:upper:]')"

# Extract the job name from the script filename (without extension)
JOB_NAME="$(basename "$SCRIPT" .py)"
# Determine the directory of the current script
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Select the appropriate run script based on the mode
case "$MODE" in
    SIESTA)
        RUN_SCRIPT="$SCRIPT_DIR/SIESTA.sh"
        ;;
    GPAW)
        RUN_SCRIPT="$SCRIPT_DIR/GPAW.sh"
        ;;
    A100)
        RUN_SCRIPT="$SCRIPT_DIR/A100.sh"
        ;;
    H200)
        RUN_SCRIPT="$SCRIPT_DIR/H200.sh"
        ;;
    *)
        echo "Unknown mode: $MODE"
        echo "Allowed modes: SIESTA, GPAW, A100, H200"
        exit 1
        ;;
esac

# Submit the job using sbatch
sbatch --job-name="$JOB_NAME" "$RUN_SCRIPT" "$SCRIPT"